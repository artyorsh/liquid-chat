# Configures app name.
# https://docs.expo.dev/versions/latest/config/app/#name
APP_NAME=liquid-chat

# Configures package and bundleIdentifier.
# https://docs.expo.dev/versions/latest/config/app/#package
# https://docs.expo.dev/versions/latest/config/app/#bundleidentifier
BUNDLE_IDENTIFIER=me.artyorsh.liquidchat.preview

####################################################################################################
# Runtime variables                                                                                #
# https://docs.expo.dev/guides/environment-variables/#reading-environment-variables-from-env-files #                                   #
####################################################################################################

# Comma-separated list of log transports
# See log/index.ts
EXPO_PUBLIC_LOG_TRANSPORTS=console,file,grafana

# Log file name for FileTransporter
EXPO_PUBLIC_LOG_FILE_NAME=app.log

# Host where Grafana/Loki is accessible
# Beware that 'localhost' won't be resolved on Android
# See https://github.com/artyorsh/rnapp-grafana
EXPO_PUBLIC_LOG_GRAFANA_HOST=http://192.168.1.10:3100

# The MLC model to use when Apple Foundation Models are not available.
# See https://www.react-native-ai.dev/docs/mlc/model-management#available-models
# See https://developer.apple.com/documentation/FoundationModels
EXPO_PUBLIC_AI_FALLBACK_MODEL=Llama-3.2-3B-Instruct

EXPO_PUBLIC_AI_FALLBACK_MODEL_SIZE=2000000000

# The minimum amount of RAM to enable on-device AI, in bytes.
EXPO_PUBLIC_AI_MEM_THRESHOLD=4000000000
